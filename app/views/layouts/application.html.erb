<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-allow-palette="<%= current_user.present? %>">
  <head>
    <meta charset="UTF-8">
    <title><%= content_for(:title) || "Med Tracker" %></title>
    <meta name="description" content="Med Tracker - Manage your medications and health with ease.">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#f8fafc">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <% unless current_user %>
      <meta name="turbo-visit-control" content="reload">
    <% end %>
    <% vapid_public_key = ENV['VAPID_PUBLIC_KEY'] || Rails.application.credentials.dig(:vapid, :public_key) %>
    <% if vapid_public_key %>
      <meta name="vapid-public-key" content="<%= vapid_public_key %>">
    <% end %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.webmanifest">
    <%= favicon_link_tag "/favicon.svg", type: "image/svg+xml" %>
    <%= favicon_link_tag "/favicon.svg", rel: "apple-touch-icon", type: "image/svg+xml" %>
    <%= javascript_include_tag "appearance_boot", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "hamburgers", "data-turbo-track": "reload" %>
    <% if current_user %>
      <%= javascript_importmap_tags %>
    <% else %>
      <%= javascript_include_tag "auth", "data-turbo-track": "reload" %>
    <% end %>
  </head>

  <body class="bg-background text-foreground transition-colors duration-300">
    <%= render Components::Layouts::Sidebar.new(current_user: current_user) %>
    <%= render Components::Layouts::Navigation.new(current_user: current_user) %>

    <% if content_for?(:flash) %>
      <%= yield :flash %>
    <% else %>
      <div id="flash">
        <%= render Components::Layouts::Flash.new(notice: notice, alert: alert, warning: flash[:warning]) %>
      </div>
    <% end %>

    <main class="<%= current_user ? 'sm:ml-20 md:ml-64' : '' %> pb-24 md:pb-0 transition-all duration-500">
      <div id="main-content">
        <%= yield %>
      </div>
    </main>
    <turbo-frame id="modal"></turbo-frame>
  </body>
</html>
